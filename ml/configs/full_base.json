{
  "_comment": "Same as full.json but scaled up to flan-t5-base, for if flan-t5-small's eval quality (ml/eval.py) doesn't clear the acceptance bar. Needs a GPU with more memory than the small run.",
  "model_name": "google/flan-t5-base",
  "train_file": "data/processed/train.jsonl",
  "val_file": "data/processed/val.jsonl",
  "output_dir": "runs/full_base",
  "max_source_length": 384,
  "max_target_length": 384,
  "per_device_train_batch_size": 8,
  "per_device_eval_batch_size": 8,
  "gradient_accumulation_steps": 4,
  "learning_rate": 2e-4,
  "num_train_epochs": 8,
  "max_train_samples": null,
  "max_val_samples": null,
  "eval_strategy": "epoch",
  "save_total_limit": 3,
  "logging_steps": 50,
  "fp16": true,
  "bf16": false,
  "seed": 42,
  "warmup_ratio": 0.05,
  "weight_decay": 0.01,
  "lr_scheduler_type": "linear",
  "generation_max_length": 384,
  "generation_num_beams": 4,
  "no_cuda": false
}
